MPRINT(EM_ASSESS):   UPP = 692654.52833;
MPRINT(EM_ASSESS):   DO SCRBIN = 1 TO 20;
MPRINT(EM_ASSESS):   LOWP = UPP - 74034.129149564;
MPRINT(EM_ASSESS):   N = NUMOBSS (SCRBIN);
