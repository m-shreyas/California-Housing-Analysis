*** Generate dummy variables for ocean_proximity ;
drop ocean_proximity_1H_OCEA ocean_proximityINLAND ocean_proximityNEAR_BAY
        ocean_proximityNEAR_OCE ;
if missing( ocean_proximity ) then do;
